# ===== LLM =====
# Выбор провайдера: mimo | glm | deepseek | qwen | openai | gemini | minimax | custom
# 'custom' — свои base_url / api_key / model
LLM_PROVIDER=mimo
LLM_API_KEY=

# Модель (если не указано — берётся дефолт провайдера)
# LLM_MODEL=mimo-v2.5-pro
# LLM_MODEL=glm-5.1
# LLM_MODEL=qwen-plus
# LLM_MODEL=gpt-4o-mini
# LLM_MODEL=deepseek-chat
# LLM_MODEL=gemini-2.0-flash
# LLM_MODEL=MiniMax-M3

# Температура (по дефолту 0.4 — баланс между точностью и креативом)
LLM_TEMPERATURE=0.4

# Свой эндпоинт (только если LLM_PROVIDER=custom)
# LLM_BASE_URL=https://api.openai.com/v1

# ===== Сервер =====
HOST=0.0.0.0
PORT=8000

# ===== Лимиты =====
MAX_UPLOAD_MB=25
MAX_SLIDES=50

# ===== История загрузок (SQLite) =====
# Путь к файлу БД. По дефолту — ./psycho_portrait.db
# DB_PATH=/var/lib/psycho_portrait/db.sqlite
