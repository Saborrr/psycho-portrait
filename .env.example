# Внешняя модель. Провайдер: mimo | glm | deepseek | qwen | openai | gemini | minimax | custom
LLM_PROVIDER=qwen
LLM_API_KEY=
# LLM_MODEL=qwen-plus
LLM_TEMPERATURE=0.3
LLM_TIMEOUT_SECONDS=120
LLM_MAX_RETRIES=2
# Не наследовать системные HTTP_PROXY/ALL_PROXY без явной необходимости.
LLM_TRUST_ENV=false
# LLM_BASE_URL=https://example.com/v1

# Обязательный ключ доступа к API приложения. Используйте длинную случайную строку.
APP_API_KEY=
# Только для разработки на полностью доверенном локальном компьютере:
ALLOW_INSECURE_LOCALHOST=false

# Слушать только локальный интерфейс при запуске без Docker.
HOST=127.0.0.1
PORT=8000
CORS_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
ENABLE_API_DOCS=false

MAX_UPLOAD_MB=25
MAX_UNPACKED_MB=150
MAX_SLIDES=50
MAX_BATCH_FILES=25

# История по умолчанию выключена. При включении ключ шифрования обязателен.
STORE_HISTORY=false
STORE_RAW_TEXT=false
DATA_RETENTION_DAYS=30
DB_PATH=./data/psycho_portrait.db
# Сгенерировать: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DATA_ENCRYPTION_KEY=
# Отдельный HMAC-ключ желателен; иначе используется DATA_ENCRYPTION_KEY.
FILE_HMAC_KEY=
